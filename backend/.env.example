# backend/.env.example
#
# SQLite 数据库文件路径。
#
# Prisma 的 file: 相对路径解析规则：
#   - CLI (migrate / generate / db push / seed via CLI) → 相对 prisma/schema.prisma 所在目录
#   - Runtime (PrismaClient via backend/src/prisma/prisma.service.ts) → 相对 backend/
# backend/src/prisma/prisma.service.ts 内部已统一为 schema 目录解析，
# 所以这里的 file:./dev.db 在 CLI 和 runtime 下都会落到 backend/prisma/dev.db。
#
DATABASE_URL="file:./dev.db"

# 后端服务端口
PORT=3000

# （后续可能用到，先留位）
# NODE_ENV=development
# LOG_LEVEL=debug
