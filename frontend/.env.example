# Copy this file to .env.local and adjust for your environment.
# NEXT_PUBLIC_API_URL is consumed by next.config.js (server-side rewrite only)
# and is used by the backend NestJS instance. The frontend only uses it to
# rewrite /api/* requests to the backend.

# Default: same host, port 3000
# NEXT_PUBLIC_API_URL=http://127.0.0.1:3000

# Public LAN access (used during development):
# NEXT_PUBLIC_API_URL=http://14.103.72.155:3000